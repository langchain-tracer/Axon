{
  "name": "@axon-ai/cli",
  "version": "1.0.12",
  "description": "CLI tool for Axon - Monitor LangChain agents in real-time",
  "type": "module",
  "bin": {
    "agent-trace": "dist/cli.js",
    "axon": "dist/cli.js",
    "axon-ai": "dist/cli.js"
  },
  "files": [
    "dist",
    "bundled",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist bundled",
    "prepublishOnly": "npm run build && npm run bundle"
  },
  "keywords": [
    "langchain",
    "tracing",
    "observability",
    "debugging",
    "ai",
    "agents",
    "monitoring",
    "cli"
  ],
  "author": "AXON AI TEAM",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/langchain-tracer/Axon.git"
  },
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "open": "^10.0.2",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/otlp-transformer": "^0.219.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/fs-extra": "^11.0.4",
    "@types/ws": "^8.5.10",
    "@types/which": "^3.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
